    wifi {
        dev_name = "aml_wifi";
        interrupt_pin = <0x00000034 0x00000052 0x00000000>;
        interrupts = <0x00000000 0x0000004d 0x00000004>;
        power_on_pin = <0x00000034 0x00000046 0x00000000>;
        dhd_static_buf;
        pinctrl-names = "default";
        pinctrl-0 = <0x00000095>;
        pwm_config = <0x00002000>;
        compatible = "amlogic,uwe5621-irq";
        status = "okay";
        irq_trigger_type = "GPIO_IRQ_HIGH";
    };
    wifi_pwm_conf {
        phandle = <0x00002000>;
        pwm_channel1_conf {
            pwms = <0x00000119 0x00000000 0x0000774d 0x00000000>;
            duty-cycle = <0x00003ba6>;
            times = <0x0000000a>;
        };
        pwm_channel2_conf {
            pwms = <0x00000119 0x00000002 0x00007724 0x00000000>;
            duty-cycle = <0x00003b92>;
            times = <0x0000000c>;
        };
    };
    wifi32k {
        compatible = "pwm-clock";
        #clock-cells = <0x00000000>;
        clock-frequency = <0x00008000>;
        pwms = <0x00000119 0x00000000 0x00007736 0x00000000>;
        phandle = <0x00002001>;
    };
    sdio-pwrseq {
        compatible = "mmc-pwrseq-simple";
        reset-gpios = <0x00000034 0x00000046 0x00000001>;
        post-power-on-delay-ms = <0x000003e8>;
        power-off-delay-us = <0x00002710>;
        clocks = <0x00002001>;
        clock-names = "ext_clock";
        phandle = <0x00002002>;
    };
