diff --git a/drivers/mmc/core/sdio_ops.c b/drivers/mmc/core/sdio_ops.c
index 96f7377..2e8a621 100644
--- a/drivers/mmc/core/sdio_ops.c
+++ b/drivers/mmc/core/sdio_ops.c
@@ -20,12 +20,20 @@ int mmc_send_io_op_cond(struct mmc_host *host, u32 ocr, u32 *rocr)
 	struct mmc_command cmd = {};
 	int i, err = 0;
 
+	dev_warn(mmc_dev(host),
+		 "lb2002-expe1 io-op-cond entry req_ocr=%#x host_ocr_avail=%#x host_ocr_avail_sdio=%#x caps=%#x caps2=%#x f_init=%u\n",
+		 ocr, host->ocr_avail, host->ocr_avail_sdio, host->caps,
+		 host->caps2, host->f_init);
+
 	cmd.opcode = SD_IO_SEND_OP_COND;
 	cmd.arg = ocr;
 	cmd.flags = MMC_RSP_SPI_R4 | MMC_RSP_R4 | MMC_CMD_BCR;
 
 	for (i = 100; i; i--) {
 		err = mmc_wait_for_cmd(host, &cmd, MMC_CMD_RETRIES);
+		dev_warn(mmc_dev(host),
+			 "lb2002-expe1 io-op-cond iter=%d err=%d resp0=%#x resp1=%#x req_ocr=%#x\n",
+			 i, err, cmd.resp[0], cmd.resp[1], ocr);
 		if (err)
 			break;
 
@@ -56,6 +64,13 @@ int mmc_send_io_op_cond(struct mmc_host *host, u32 ocr, u32 *rocr)
 	if (rocr)
 		*rocr = cmd.resp[mmc_host_is_spi(host) ? 1 : 0];
 
+	dev_warn(mmc_dev(host),
+		 "lb2002-expe1 io-op-cond exit err=%d final_resp0=%#x final_resp1=%#x rocr=%#x busy_bit=%u spi=%u\n",
+		 err, cmd.resp[0], cmd.resp[1],
+		 rocr ? *rocr : 0,
+		 mmc_host_is_spi(host) ? !!(cmd.resp[1] & MMC_CARD_BUSY) :
+					  !!(cmd.resp[0] & MMC_CARD_BUSY),
+		 mmc_host_is_spi(host) ? 1 : 0);
 	return err;
 }
 
