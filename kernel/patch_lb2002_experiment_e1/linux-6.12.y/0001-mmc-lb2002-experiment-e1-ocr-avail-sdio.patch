diff --git a/drivers/mmc/core/host.c b/drivers/mmc/core/host.c
index 5a01b9b..87d9419 100644
--- a/drivers/mmc/core/host.c
+++ b/drivers/mmc/core/host.c
@@ -275,6 +275,11 @@ int mmc_of_parse(struct mmc_host *host)
 	u32 bus_width, drv_type, cd_debounce_delay_ms;
 	int ret;
 
+	dev_warn(host->parent,
+		 "lb2002-expe1 mmc-of-parse entry ocr_avail=%#x ocr_avail_sdio=%#x caps=%#x caps2=%#x pm_caps=%#x f_max=%u\n",
+		 host->ocr_avail, host->ocr_avail_sdio, host->caps, host->caps2,
+		 host->pm_caps, host->f_max);
+
 	if (!dev || !dev_fwnode(dev))
 		return 0;
 
@@ -427,6 +432,10 @@ int mmc_of_parse(struct mmc_host *host)
 	device_property_read_u32(dev, "post-power-on-delay-ms",
 				 &host->ios.power_delay_ms);
 
+	dev_warn(host->parent,
+		 "lb2002-expe1 mmc-of-parse exit ocr_avail=%#x ocr_avail_sdio=%#x caps=%#x caps2=%#x pm_caps=%#x f_max=%u\n",
+		 host->ocr_avail, host->ocr_avail_sdio, host->caps, host->caps2,
+		 host->pm_caps, host->f_max);
 	return mmc_pwrseq_alloc(host);
 }
 
diff --git a/drivers/mmc/core/regulator.c b/drivers/mmc/core/regulator.c
index 8198960..fb9e351 100644
--- a/drivers/mmc/core/regulator.c
+++ b/drivers/mmc/core/regulator.c
@@ -250,6 +250,10 @@ int mmc_regulator_get_supply(struct mmc_host *mmc)
 	struct device *dev = mmc_dev(mmc);
 	int ret;
 
+	dev_warn(dev,
+		 "lb2002-expe1 regulator-get-supply entry ocr_avail=%#x ocr_avail_sdio=%#x\n",
+		 mmc->ocr_avail, mmc->ocr_avail_sdio);
+
 	mmc->supply.vmmc = devm_regulator_get_optional(dev, "vmmc");
 	mmc->supply.vqmmc = devm_regulator_get_optional(dev, "vqmmc");
 
@@ -275,6 +279,11 @@ int mmc_regulator_get_supply(struct mmc_host *mmc)
 		dev_dbg(dev, "No vqmmc regulator found\n");
 	}
 
+	dev_warn(dev,
+		 "lb2002-expe1 regulator-get-supply exit ocr_avail=%#x ocr_avail_sdio=%#x vmmc_err=%d vqmmc_err=%d\n",
+		 mmc->ocr_avail, mmc->ocr_avail_sdio,
+		 IS_ERR(mmc->supply.vmmc) ? PTR_ERR(mmc->supply.vmmc) : 0,
+		 IS_ERR(mmc->supply.vqmmc) ? PTR_ERR(mmc->supply.vqmmc) : 0);
 	return 0;
 }
 EXPORT_SYMBOL_GPL(mmc_regulator_get_supply);
diff --git a/drivers/mmc/core/sdio.c b/drivers/mmc/core/sdio.c
