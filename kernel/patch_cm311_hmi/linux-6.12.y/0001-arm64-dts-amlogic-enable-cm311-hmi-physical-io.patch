diff --git a/arch/arm64/boot/dts/amlogic/meson-g12a-s905l3a-e900v22c.dts b/arch/arm64/boot/dts/amlogic/meson-g12a-s905l3a-e900v22c.dts
index d942f2cd6..f46382d08 100644
--- a/arch/arm64/boot/dts/amlogic/meson-g12a-s905l3a-e900v22c.dts
+++ b/arch/arm64/boot/dts/amlogic/meson-g12a-s905l3a-e900v22c.dts
@@ -157,3 +157,92 @@ &ethmac {
 	phy-mode = "rmii";
 	status = "okay";
 };
+
+/* CM311-1A HMI physical profile:
+ * UART_A GPIOX_12/GPIOX_13, UART_AO_B GPIOAO_8/GPIOAO_9,
+ * I2C_EE_M0 on GPIOC_5/GPIOC_6 for DS3231,
+ * EE PWM candidates on GPIOX_3/GPIOX_5/GPIOX_6.
+ */
+&{/reserved-memory} {
+	ramoops: ramoops@0 {
+		compatible = "ramoops";
+		reg = <0x0 0x7fe00000 0x0 0x00200000>;
+		no-map;
+		record-size = <0x00040000>;
+		console-size = <0x00040000>;
+		pmsg-size = <0x00020000>;
+		ecc-size = <16>;
+	};
+};
+
+&{/leds/power_led} {
+	/* CM311 HMI: GPIOAO_11 / GPIO608 is the red status LED. */
+	gpios = <&gpio_ao GPIOAO_11 GPIO_ACTIVE_HIGH>;
+	default-state = "off";
+};
+
+&{/leds/net_led} {
+	status = "disabled";
+};
+
+&{/leds/remote_led} {
+	/* CM311 HMI: GPIOAO_10 / GPIO607 is the green status LED. */
+	gpios = <&gpio_ao GPIOAO_10 GPIO_ACTIVE_HIGH>;
+	default-state = "off";
+	/delete-property/ linux,default-trigger;
+};
+
+&sd_emmc_a {
+	status = "disabled";
+};
+
+&sd_emmc_b {
+	/* GPIOC_5/GPIOC_6 are used by the CM311 HMI DS3231 I2C bus. */
+	status = "disabled";
+};
+
+&uart_B {
+	status = "disabled";
+};
+
+&uart_A {
+	status = "okay";
+	pinctrl-0 = <&uart_a_pins>;
+	pinctrl-names = "default";
+};
+
+&uart_AO_B {
+	status = "okay";
+	pinctrl-0 = <&uart_ao_b_8_9_pins>;
+	pinctrl-names = "default";
+};
+
+&i2c0 {
+	status = "okay";
+	pinctrl-0 = <&i2c0_sda_c_pins>, <&i2c0_sck_c_pins>;
+	pinctrl-names = "default";
+	#address-cells = <1>;
+	#size-cells = <0>;
+
+	ds3231: rtc@68 {
+		compatible = "maxim,ds3231";
+		reg = <0x68>;
+	};
+};
+
+&pwm_cd {
+	status = "okay";
+	pinctrl-0 = <&pwm_c_x5_pins>, <&pwm_d_x3_pins>;
+	pinctrl-names = "default";
+};
+
+&pwm_ab {
+	status = "okay";
+	pinctrl-0 = <&pwm_a_pins>;
+	pinctrl-names = "default";
+};
+
+&spdifout {
+	/*
+	 * Keep the SPDIFOUT component available for the U200 sound card, but
+	 * do not claim an external SPDIF pin. GPIOAO_10 is the CM311 HMI green
+	 * status LED, so it must remain under gpio-leds control.
+	 */
+	/delete-property/ pinctrl-0;
+	/delete-property/ pinctrl-names;
+};
+
