+static bool meson_mmc_lb2002_expb_is_sdio(struct meson_host *host)
+{
+	return !strcmp(dev_name(host->dev), "ffe05000.sd");
+}
+
+static void meson_mmc_lb2002_expb_apply_android_sdio_regs(struct meson_host *host,
+							  const char *where)
+{
+	u32 gclock, gadjust, cfg;
+
+	if (!meson_mmc_lb2002_expb_is_sdio(host))
+		return;
+
+	gclock = readl(host->regs + SD_EMMC_CLOCK);
+	gadjust = readl(host->regs + host->data->adjust);
+	cfg = readl(host->regs + SD_EMMC_CFG);
+	dev_warn(host->dev,
+		 "lb2002-expb %s before gclock=%#08x gadjust=%#08x cfg=%#08x\n",
+		 where, gclock, gadjust, cfg);
+
+	writel(0x10000345, host->regs + SD_EMMC_CLOCK);
+	writel(0x32000, host->regs + host->data->adjust);
+
+	gclock = readl(host->regs + SD_EMMC_CLOCK);
+	gadjust = readl(host->regs + host->data->adjust);
+	cfg = readl(host->regs + SD_EMMC_CFG);
+	dev_warn(host->dev,
+		 "lb2002-expb %s after gclock=%#08x gadjust=%#08x cfg=%#08x\n",
+		 where, gclock, gadjust, cfg);
+}
